  { name:"Şırnak", region:"Güneydoğu Anadolu", icon:"🌊", tags:["Dicle","Cudi Dağı","sınır"], desc:"Dicle'nin kolları ve Cudi Dağı efsanesiyle bilinen, üç sınıra yakın şehir.", yemek:["Mırra kahvesi","Tandır ekmeği","Kuzu tandır"], gezilek:["Dicle Nehri","Cudi Dağı","Uludere","İdil"], ozellik:["Dicle'nin üst havzası","Nuh'un Gemisi efsanesi Cudi Dağı","İran ve Irak sınırına yakın"] },
  { name:"Tekirdağ", region:"Marmara", icon:"🍷", tags:["köfte","şarap","Trakya"], desc:"Trakya bağları, şarabı ve dünyaca ünlü köftesiyle öne çıkan Marmara kenti.", yemek:["Tekirdağ köftesi","Rakı","Trakya şarabı"], gezilek:["Rakoczi Müzesi","Namık Kemal Evi","Şarköy sahilleri"], ozellik:["Türk şarap ve rakı üretiminin kalbi","Tekirdağ köftesi coğrafi işaret","Marmara Denizi kıyısı"] },
  { name:"Tokat", region:"Karadeniz", icon:"🏺", tags:["Tokat kebabı","Ballıca Mağarası","tarih"], desc:"Tarihi Selçuklu eserleri, bez boyama sanatı ve Tokat kebabıyla ünlü.", yemek:["Tokat kebabı","Bamya çorbası","Pestil"], gezilek:["Ballıca Mağarası","Tokat Kalesi","Niksar","Zile Kalesi"], ozellik:["Ballıca Mağarası – Türkiye'nin en büyük mağaralarından","Tokat kebabı tescilli coğrafi işaret","Komnenler döneminden kalma Panaghia Kilisesi"] },
  { name:"Trabzon", region:"Karadeniz", icon:"⚽", tags:["Sümela","Uzungöl","futbol"], desc:"Sümela Manastırı, Uzungöl ve Trabzonspor ile dünyada tanınan Karadeniz şehri.", yemek:["Kuymak","Hamsi pilavı","Laz böreği","Vakfıkebir ekmeği"], gezilek:["Sümela Manastırı","Uzungöl","Trabzon Ayasofyası","Atatürk Köşkü"], ozellik:["UNESCO geçici listesi Sümela Manastırı","Trabzonspor köklü futbol kültürü","Uzungöl masalsı manzara"] },
  { name:"Tunceli", region:"Doğu Anadolu", icon:"🦅", tags:["Munzur","doğa","alevi"], desc:"Türkiye'nin en az nüfuslu illerinden; el değmemiş Munzur doğası ve Alevi kültürü.", yemek:["Kuzu kavurma","Yayla çorbası","Bal"], gezilek:["Munzur Vadisi Milli Parkı","Tunceli Kalesi","Pülümür Vadisi"], ozellik:["Türkiye'nin en temiz havası","Alevi kültürünün yaşayan merkezi","Munzur – vahşi nehir vadisi"] },
  { name:"Uşak", region:"Ege", icon:"🏺", tags:["halı","Karun hazinesi","kanyon"], desc:"Tarihi halı dokuma geleneği ve Karun Hazinesi ile öne çıkan, Ulubey Kanyonu'na ev sahipliği.", yemek:["Güveç","Keşkek","Kavurma"], gezilek:["Ulubey Kanyonu","Uşak Müzesi (Karun Hazinesi)","Blaundus Antik Kenti"], ozellik:["Karun Hazinesi – Dünyanın önemli hazinelerinden","Ulubey Kanyonu muhteşem manzara","Türk halı dokuma sanatı"] },
  { name:"Van", region:"Doğu Anadolu", icon:"🐱", tags:["Van Gölü","Van kedisi","kahvaltı"], desc:"Van Gölü, eşsiz kahvaltı kültürü ve iki renkli gözlü beyaz Van kedisiyle dünyaca ünlü.", yemek:["Van kahvaltısı","Otlu peynir","İnci kefali","Kavut"], gezilek:["Van Kalesi","Akdamar Kilisesi","Van Gölü","Çavuştepe"], ozellik:["Van kedisi – dünyada nadir beyaz gözlü kedi","Akdamar Kilisesi – 1000 yıllık Ermeni mirası","Van kahvaltısı Türkiye'nin en zengini"] },
  { name:"Yalova", region:"Marmara", icon:"🌹", tags:["termal","Atatürk","gül"], desc:"İstanbul'a yakınlığı, termal kaynakları ve gülleriyle sayfiye şehri.", yemek:["Balık","Midye","Deniz ürünleri"], gezilek:["Termal Kaplıcaları","Atatürk Köşkü","Gülbahçesi"], ozellik:["Atatürk'ün en sevdiği tatil yeri","İstanbul'a feribot bağlantısı","Termal turizm cenneti"] },
  { name:"Yozgat", region:"İç Anadolu", icon:"🌲", tags:["Çamlık","orman","tarih"], desc:"Türkiye'nin ilk orman parkı Çamlık Milli Parkı'na ev sahipliği yapan şehir.", yemek:["Tarhana","Yozgat çorbası","Keşkek"], gezilek:["Çamlık Milli Parkı","Alişar Höyüğü","Sarıkaya Termal"], ozellik:["Türkiye'nin ilk milli parkı (1940)","Hitit dönemi Alişar Höyüğü","Sarıkaya termal kaynakları"] },
  { name:"Zonguldak", region:"Batı Karadeniz", icon:"⛏️", tags:["kömür","Gökgöl Mağarası","deniz"], desc:"Türkiye'nin kömür madenciliği merkezi; Gökgöl Mağarası'nın kristal harikalarına ev sahipliği.", yemek:["Hamsi","Mısır ekmeği","Fındık"], gezilek:["Gökgöl Mağarası","Ereğli sahilleri","Çaycuma"], ozellik:["Türkiye taş kömürü üretiminin merkezi","Gökgöl Mağarası – kristal oluşumları","Karadeniz kıyısı"] },
];

const regions = ["Tümü", ...new Set(cities.map(c => c.region))].sort((a,b) => a==="Tümü"?-1:b==="Tümü"?1:a.localeCompare(b,"tr"));
let activeRegion = "Tümü";

function init() {
  const rf = document.getElementById("rfilter");
  regions.forEach(r => {
    const btn = document.createElement("button");
    btn.className = "rbtn" + (r === "Tümü" ? " active" : "");
    btn.textContent = r;
    btn.onclick = () => { activeRegion = r; document.querySelectorAll(".rbtn").forEach(b => b.classList.remove("active")); btn.classList.add("active"); render(); };
    rf.appendChild(btn);
  });
  render();
}

function render() {
  const q = document.getElementById("search").value.toLowerCase().trim();
  const filtered = cities.filter(c => {
    const regionOk = activeRegion === "Tümü" || c.region === activeRegion;
    const queryOk = !q || c.name.toLowerCase().includes(q) || c.region.toLowerCase().includes(q) || c.tags.some(t => t.toLowerCase().includes(q));
    return regionOk && queryOk;
  }).sort((a,b) => a.name.localeCompare(b.name,"tr"));
  const grid = document.getElementById("grid");
  document.getElementById("count").textContent = `${filtered.length} il gösteriliyor`;
  grid.innerHTML = "";
  if (!filtered.length) { grid.innerHTML = '<div class="no-results">🔍 Sonuç bulunamadı.</div>'; return; }
  filtered.forEach(c => {
    const card = document.createElement("div");
    card.className = "card";
    card.innerHTML = `<div class="card-header"><span class="card-icon">${c.icon}</span><span class="card-name">${c.name}</span></div><div class="card-region">${c.region} Bölgesi</div><div class="tags">${c.tags.map(t=>`<span class="tag">${t}</span>`).join("")}</div>`;
    card.onclick = () => openModal(c);
    grid.appendChild(card);
  });
}

function openModal(c) {
  document.getElementById("mcontent").innerHTML = `
    <div class="modal-emoji">${c.icon}</div>
    <div class="modal-title">${c.name}</div>
    <div class="modal-region-label">📍 ${c.region} Bölgesi</div>
    <div class="modal-desc">${c.desc}</div>
    <div class="section-title">🍽️ Yöresel Lezzetler</div>
    <ul>${c.yemek.map(y=>`<li>${y}</li>`).join("")}</ul>
    <div class="section-title">🗺️ Gezilecek Yerler</div>
    <ul>${c.gezilek.map(y=>`<li>${y}</li>`).join("")}</ul>
    <div class="section-title">⭐ Öne Çıkan Özellikler</div>
    <div class="badge-wrap">${c.ozellik.map(o=>`<span class="badge">${o}</span>`).join("")}</div>
  `;
  document.getElementById("overlay").classList.add("open");
  document.body.style.overflow = "hidden";
}

function closeModal() { document.getElementById("overlay").classList.remove("open"); document.body.style.overflow = ""; }
function closeOverlay(e) { if (e.target === document.getElementById("overlay")) closeModal(); }
document.addEventListener("keydown", e => { if (e.key === "Escape") closeModal(); });

function filter() { render(); }
init();
</script>
</body>
</html>