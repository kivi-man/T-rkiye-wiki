<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Türkiye 81 İl Rehberi</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #f7f6f2;
    --surface: #ffffff;
    --surface2: #f0eeea;
    --border: rgba(0,0,0,0.1);
    --border2: rgba(0,0,0,0.2);
    --text: #1a1a1a;
    --text2: #555;
    --text3: #888;
    --accent: #c0392b;
    --accent-light: #fdecea;
    --radius: 12px;
    --radius-sm: 8px;
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
  header { background: var(--accent); color: #fff; padding: 2rem 1.5rem 1.5rem; text-align: center; }
  header h1 { font-size: 2rem; font-weight: 700; margin-bottom: 0.4rem; letter-spacing: -0.5px; }
  header p { font-size: 1rem; opacity: 0.85; }
  .controls { background: var(--surface); border-bottom: 1px solid var(--border); padding: 1rem 1.5rem; position: sticky; top: 0; z-index: 10; }
  .search-wrap { display: flex; gap: 10px; margin-bottom: 0.75rem; }
  .search-wrap input { flex: 1; padding: 10px 14px; border: 1px solid var(--border2); border-radius: var(--radius-sm); font-size: 15px; background: var(--bg); color: var(--text); outline: none; }
  .search-wrap input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(192,57,43,0.12); }
  .region-filter { display: flex; gap: 6px; flex-wrap: wrap; }
  .rbtn { font-size: 12px; padding: 5px 13px; border: 1px solid var(--border2); border-radius: 20px; background: var(--surface); color: var(--text2); cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .rbtn:hover { border-color: var(--accent); color: var(--accent); }
  .rbtn.active { background: var(--accent); color: #fff; border-color: var(--accent); font-weight: 600; }
  .count-bar { padding: 0.6rem 1.5rem; font-size: 13px; color: var(--text3); }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; padding: 0 1.5rem 2rem; }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem 1.1rem; cursor: pointer; transition: box-shadow 0.15s, transform 0.12s, border-color 0.15s; }
  .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.1); transform: translateY(-2px); border-color: var(--accent); }
  .card-header { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  .card-icon { font-size: 22px; line-height: 1; }
  .card-name { font-size: 15px; font-weight: 600; color: var(--text); }
  .card-region { font-size: 11px; color: var(--text3); margin-bottom: 8px; }
  .tags { display: flex; flex-wrap: wrap; gap: 4px; }
  .tag { font-size: 11px; padding: 2px 8px; border-radius: 10px; background: var(--surface2); color: var(--text2); }
  .no-results { text-align: center; padding: 4rem; color: var(--text3); font-size: 16px; grid-column: 1/-1; }
  /* Modal */
  .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 100; align-items: center; justify-content: center; padding: 1rem; }
  .overlay.open { display: flex; }
  .modal { background: var(--surface); border-radius: var(--radius); max-width: 500px; width: 100%; max-height: 88vh; overflow-y: auto; padding: 1.5rem; position: relative; }
  .modal-close { position: absolute; top: 1rem; right: 1rem; background: var(--surface2); border: none; border-radius: 50%; width: 32px; height: 32px; cursor: pointer; font-size: 18px; color: var(--text2); display: flex; align-items: center; justify-content: center; }
  .modal-emoji { font-size: 40px; margin-bottom: 0.5rem; }
  .modal-title { font-size: 24px; font-weight: 700; margin-bottom: 2px; }
  .modal-region-label { font-size: 13px; color: var(--accent); font-weight: 500; margin-bottom: 0.75rem; }
  .modal-desc { font-size: 14px; color: var(--text2); line-height: 1.65; margin-bottom: 1rem; border-left: 3px solid var(--accent); padding-left: 0.75rem; background: var(--accent-light); border-radius: 0 6px 6px 0; padding: 0.6rem 0.75rem; }
  .section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text3); margin-bottom: 6px; margin-top: 1rem; }
  .modal ul { list-style: none; }
  .modal ul li { font-size: 14px; color: var(--text); padding: 4px 0; border-bottom: 1px solid var(--border); display: flex; gap: 8px; }
  .modal ul li:last-child { border-bottom: none; }
  .modal ul li::before { content: "›"; color: var(--accent); font-weight: bold; flex-shrink: 0; }
  .badge-wrap { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 0.5rem; }
  .badge { font-size: 12px; padding: 3px 10px; border-radius: 20px; background: var(--accent-light); color: var(--accent); font-weight: 500; }
</style>
</head>
<body>

<header>
  <h1>🇹🇷 Türkiye 81 İl Rehberi</h1>
  <p>Her ilin kültürü, lezzetleri ve gezilecek yerleri</p>
</header>

<div class="controls">
  <div class="search-wrap">
    <input type="text" id="search" placeholder="🔍 İl adı veya özellik ara..." oninput="filter()" />
  </div>
  <div class="region-filter" id="rfilter"></div>
</div>

<div class="count-bar" id="count"></div>
<div class="grid" id="grid"></div>

<div class="overlay" id="overlay" onclick="closeOverlay(event)">
  <div class="modal" id="modal">
    <button class="modal-close" onclick="closeModal()" title="Kapat">✕</button>
    <div id="mcontent"></div>
  </div>
</div>

<script>
const cities = [
  { name:"Adana", region:"Akdeniz", icon:"🌶️", tags:["kebap","narenciye","tarih"], desc:"Türkiye'nin 4. büyük şehri. Sıcak iklimi ve bereketli Çukurova ovası ile ünlüdür.", yemek:["Adana kebap","Şalgam suyu","Bici bici","Kısır"], gezilek:["Taşköprü","Sabancı Merkez Camii","Çukurova Botanik Bahçesi","Anavarza Antik Kenti"], ozellik:["Türkiye'nin narenciye başkenti","Seyhan Nehri kıyısında kurulu","Türkiye'nin önemli tekstil merkezi"] },
  { name:"Adıyaman", region:"Güneydoğu Anadolu", icon:"🏛️", tags:["Nemrut","tarih","kültür"], desc:"UNESCO Dünya Mirası Nemrut Dağı'na ev sahipliği yapan tarihi şehir.", yemek:["Çiğ köfte","Katmer","Kaburga dolması"], gezilek:["Nemrut Dağı","Perre Antik Kenti","Arsemia","Cendere Köprüsü"], ozellik:["UNESCO Dünya Mirası Nemrut Dağı","Kommagene Krallığı'nın merkezi","Dev heykel başları ile ünlü"] },
  { name:"Afyonkarahisar", region:"Ege", icon:"🌸", tags:["kaymak","termal","tarih"], desc:"Haşhaş üretimi, kaymak ve termal tesisleriyle ünlü, stratejik öneme sahip şehir.", yemek:["Sütlü lokum","Kaymak","Sucuk","Pişi"], gezilek:["Afyon Kalesi","Frigya Vadisi","Termal tesisler","İscehisar"], ozellik:["Türkiye'nin kaymak başkenti","Kurtuluş Savaşı'nın kritik şehri","Termal turizm merkezi"] },
  { name:"Ağrı", region:"Doğu Anadolu", icon:"🏔️", tags:["Ağrı Dağı","doğa","kültür"], desc:"Türkiye'nin en yüksek dağı Ağrı Dağı'na (5137m) ev sahipliği yapan sınır şehri.", yemek:["Etli ekmek","Kavut","Tandır kebabı"], gezilek:["Ağrı Dağı (5137m)","İshak Paşa Sarayı","Diyadin Termal Tesisleri","Balık Gölü"], ozellik:["Ağrı Dağı – Türkiye'nin en yüksek zirvesi","İshak Paşa Sarayı muhteşem mimarisi","Nuh'un Gemisi efsanesinin yeri"] },
  { name:"Aksaray", region:"İç Anadolu", icon:"🌋", tags:["İhlara","doğa","Selçuklu"], desc:"İhlara Vadisi ve Selçuklu eserleriyle öne çıkan İpek Yolu üzerindeki şehir.", yemek:["Tarhana çorbası","Pastırma","Köfte"], gezilek:["İhlara Vadisi (14km)","Selime Katedrali","Sultanhani Kervansarayı","Hasan Dağı"], ozellik:["İpek Yolu güzergahında önemli şehir","İhlara Vadisi 14km uzunluğunda","Selçuklu dönemi kervansarayları"] },
  { name:"Amasya", region:"Karadeniz", icon:"🍎", tags:["elma","tarih","Pontus"], desc:"Yeşilırmak kıyısındaki tarihi Osmanlı evleri ve kaya mezarlarıyla ünlü. Pontus Krallığı başkenti.", yemek:["Amasya elması","Mantı","Tarhana"], gezilek:["Kaya Mezarları","Yalıboyu Osmanlı Evleri","Amasya Kalesi","Hatuniye Camii"], ozellik:["Pontus Krallığı başkenti","UNESCO geçici listesinde","Elma üretimi ile ünlü"] },
  { name:"Ankara", region:"İç Anadolu", icon:"🏛️", tags:["başkent","tarih","müze"], desc:"Türkiye Cumhuriyeti'nin başkenti; siyasi, kültürel ve diplomatik merkezi.", yemek:["Ankara tavası","Döner kebap","Baklava"], gezilek:["Anıtkabir","Kocatepe Camii","Ankara Kalesi","Anadolu Medeniyetleri Müzesi"], ozellik:["Türkiye Cumhuriyeti'nin başkenti","Anadolu Medeniyetleri Müzesi – Dünyanın en önemli müzelerinden","Nüfus 5.7 milyon"] },
  { name:"Antalya", region:"Akdeniz", icon:"🏖️", tags:["turizm","deniz","tarih"], desc:"Türkiye'nin turizm başkenti; yıllık 15 milyonu aşkın turist ağırlıyor.", yemek:["Piyaz","Tahini piyaz","Kabak tatlısı","Şiş kebap"], gezilek:["Kaleiçi (tarihi merkez)","Düden Şelalesi","Perge Antik Kenti","Aspendos Tiyatrosu"], ozellik:["Türkiye turizm başkenti","Turkuaz kıyılar ve Toros Dağları","Yılda 15 milyon+ ziyaretçi"] },
  { name:"Ardahan", region:"Doğu Anadolu", icon:"🐄", tags:["kaşar","Çıldır Gölü","doğa"], desc:"Türkiye'nin en soğuk şehirlerinden biri; kaşar peyniri ve donduğunda üzerinde at koşulan Çıldır Gölü ile ünlü.", yemek:["Kars kaşarı","Çıldır balığı","Yöresel bal"], gezilek:["Çıldır Gölü","Şeytan Kalesi","Kura Nehri","Posof"], ozellik:["Çıldır Gölü kışın tamamen buz tutar","Kaşar peyniri üretim merkezi","Doğu Anadolu'nun sakin köşesi"] },
  { name:"Artvin", region:"Karadeniz", icon:"🌿", tags:["doğa","festival","orman"], desc:"Türkiye'nin en yeşil kenti; derin vadileri ve Kafkasör Boğa Güreşi Festivali ile ünlü.", yemek:["Mısır ekmeği","Muhlama","Turşu"], gezilek:["Borcka Karagöl","Şavşat Ormanları","Artvin Kalesi","Kafkasör"], ozellik:["Türkiye'nin en ormanlık ili","Kafkasör Kültür ve Sanat Festivali","Çoruh Nehri rafting"] },
  { name:"Aydın", region:"Ege", icon:"🫒", tags:["Efes","incir","zeytin"], desc:"Verimli Menderes Ovası, UNESCO Efes Antik Kenti ve dünyaca ünlü Aydın inciri ile tanınan.", yemek:["İncir tatlısı","Zeytinyağlı yaprak sarma","Boyoz"], gezilek:["Efes Antik Kenti","Didim Apollon Tapınağı","Priene","Milet"], ozellik:["UNESCO Efes Antik Kenti","Türkiye incir ihracatı başkenti","Antik Yunan mirasının kalbi"] },
  { name:"Balıkesir", region:"Marmara", icon:"🐟", tags:["deniz","zeytin","Cunda"], desc:"Hem Ege hem Marmara kıyısına sahip, zeytinyağı ve kıyı turizmiyle öne çıkan şehir.", yemek:["Balık ekmek","Zeytin ezmesi","Balıkesir pidesi"], gezilek:["Ayvalık","Cunda Adası","Erdek","Edremit Körfezi"], ozellik:["Hem Ege hem Marmara kıyısına sahip","Türkiye zeytinyağı üretim merkezi","Cunda'nın Rum mirası"] },
  { name:"Bartın", region:"Karadeniz", icon:"🌲", tags:["doğa","Küre Dağları","kıyı"], desc:"Küre Dağları Milli Parkı ve Karadeniz kıyısıyla küçük ama doğa açısından zengin şehir.", yemek:["Mısır ekmeği","Kara lahana yemeği","Hamsi"], gezilek:["Küre Dağları Milli Parkı","Bartın Çayı","İnkumu Sahili","Amasra"], ozellik:["Küre Dağları eşsiz doğası","Amasra antik liman kenti","Karadeniz sahil şeridi"] },
  { name:"Batman", region:"Güneydoğu Anadolu", icon:"🛢️", tags:["petrol","Hasankeyf","nehir"], desc:"Türkiye'nin petrol üretim merkezi; dünya mirası Hasankeyf ve Batman Nehri kıyısında.", yemek:["Çiğ köfte","İçli köfte","Katlama"], gezilek:["Hasankeyf","Malabadi Köprüsü","Batman Barajı"], ozellik:["Türkiye petrol üretim merkezi","Hasankeyf 12.000 yıllık tarihe sahip","Malabadi Köprüsü ortaçağ eseri"] },
  { name:"Bayburt", region:"Doğu Anadolu", icon:"🏰", tags:["kale","Çoruh","küçük il"], desc:"Türkiye'nin en az nüfuslu ili; ortaçağ kalesi ve Çoruh Nehri ile bilinen küçük şehir.", yemek:["Tirit","Kadayıf dolması","Tutmaç çorbası"], gezilek:["Bayburt Kalesi","Deli Duman Mağarası","Çoruh Nehri"], ozellik:["Türkiye'nin en az nüfuslu ili","Çoruh Nehri rafting rotası","Ortaçağ kalesi"] },
  { name:"Bilecik", region:"Marmara", icon:"⚔️", tags:["Osmanlı","İnegöl köftesi","tarih"], desc:"Osmanlı İmparatorluğu'nun doğduğu topraklara ev sahipliği yapan tarihi şehir.", yemek:["İnegöl köftesi","Şeftali","Dut pekmezi"], gezilek:["Söğüt – Osmanlı'nın kuruluşu","Lefke Kapısı","İnegöl"], ozellik:["Osmanlı'nın kuruluş yeri Söğüt","İnegöl köftesinin anavatanı","Tarihi ipek yolu güzergahı"] },
  { name:"Bingöl", region:"Doğu Anadolu", icon:"🍯", tags:["bal","doğa","şelale"], desc:"Ari çiçeklerinden üretilen eşsiz balı ve el değmemiş doğasıyla ünlü sakin şehir.", yemek:["Bingöl balı","Kavut","Kızartma"], gezilek:["Yelesen Şelalesi","Yedisu İlçesi","Solhan","Gayt Şelalesi"], ozellik:["Türkiye'nin en kaliteli balı","El değmemiş dağ doğası","Şelale bolluğu"] },
  { name:"Bitlis", region:"Doğu Anadolu", icon:"🌺", tags:["Van Gölü","Nemrut Krateri","Ahlat"], desc:"Van Gölü kıyısında, Nemrut Krateri ve Selçuklu mezarlıkları ile tarihi şehir.", yemek:["Otlu peynir","Kavut","Tandır çorbası"], gezilek:["Nemrut Krateri Gölü","Ahlat Selçuklu Mezarlığı","Tatvan","Van Gölü"], ozellik:["Ahlat UNESCO geçici listesinde","Nemrut Krateri doğal harikası","Selçuklu mezar taşları"] },
  { name:"Bolu", region:"Batı Karadeniz", icon:"🌲", tags:["Abant","mutfak","kayak"], desc:"Abant Gölü, Yedigöller, kayak merkezleri ve Mengen aşçılarıyla ünlü dört mevsim güzel şehir.", yemek:["Mengen mutfağı","Mantar yemekleri","Alabalık"], gezilek:["Abant Gölü","Yedigöller Milli Parkı","Kartalkaya Kayak Merkezi","Göynük"], ozellik:["Türk aşçılığının merkezi Mengen","Yedigöller – muhteşem sonbahar manzarası","Abant Gölü doğal güzelliği"] },
  { name:"Burdur", region:"Akdeniz", icon:"🦩", tags:["flamingo","Salda","Sagalassos"], desc:"Dünyanın önemli flamingo yaşam alanı Burdur Gölü ve 'Türkiye'nin Maldivleri' Salda Gölü burada.", yemek:["Kuzu tandır","Keşkek","Pöç"], gezilek:["Burdur Gölü","Sagalassos Antik Kenti","Salda Gölü","Kremna"], ozellik:["Salda Gölü – Türkiye'nin Maldivleri","Flamingo göç güzergahı","Sagalassos antik kenti"] },
  { name:"Bursa", region:"Marmara", icon:"🌿", tags:["İskender","Uludağ","Osmanlı"], desc:"Osmanlı'nın ilk başkenti; İpek Yolu mirası, UNESCO köyü Cumalıkızık ve Uludağ ile ünlü.", yemek:["İskender kebap","Kestane şekeri","Candır","Tahini helvası"], gezilek:["Uludağ","Yeşil Türbe","Kapalıçarşı","Cumalıkızık Köyü"], ozellik:["Osmanlı'nın ilk başkenti","İpek ticaretinin kalbi","UNESCO Cumalıkızık Köyü"] },
  { name:"Çanakkale", region:"Marmara", icon:"⚓", tags:["Truva","Gelibolu","savaş"], desc:"Dünya savaş tarihi Gelibolu ve UNESCO Truva antik şehriyle dünyaca ünlü.", yemek:["Sardalye","Kumru sandviç","Ezine peyniri"], gezilek:["Truva Antik Kenti","Gelibolu Yarımadası","Assos","Bozcaada"], ozellik:["UNESCO Truva Antik Kenti","Çanakkale Savaşı 1915 anma merkezi","Bozcaada şarabı"] },
  { name:"Çankırı", region:"İç Anadolu", icon:"🧂", tags:["tuz","Ilgaz","termal"], desc:"Tuz mağaraları, şifalı suları ve Ilgaz Dağı kayak merkezi ile öne çıkan.", yemek:["Tarhana","Keşkek","Saç kavurma"], gezilek:["Tuz Mağarası","Ilgaz Dağı Milli Parkı","Çankırı Kalesi"], ozellik:["Tuz mağarası terapi merkezi","Ilgaz kayak ve doğa parkı","Roma dönemi eserleri"] },
  { name:"Çorum", region:"Karadeniz", icon:"🫘", tags:["leblebi","Hitit","Hattuşa"], desc:"Hitit medeniyetinin kalbi ve dünyaca ünlü leblebisiyle tanınan tarihi şehir.", yemek:["Leblebi","Çorum pastırması","Pide"], gezilek:["Hattuşa – Hitit Başkenti","Yazılıkaya","Alacahöyük"], ozellik:["UNESCO Hattuşa Dünya Mirası","Hitit medeniyetinin merkezi","Türkiye leblebi başkenti"] },
  { name:"Denizli", region:"Ege", icon:"🌊", tags:["Pamukkale","termal","Hierapolis"], desc:"Dünyanın harikası Pamukkale travertenleri ve Hierapolis antik şehriyle dünyaca ünlü.", yemek:["Höşmerim","Çökertme kebabı","Bamya çorbası"], gezilek:["Pamukkale Travertenleri","Hierapolis","Laodikeia","Kaklik Mağarası"], ozellik:["UNESCO Pamukkale-Hierapolis","Yılda 2 milyon+ ziyaretçi","Termal turizm cenneti"] },
  { name:"Diyarbakır", region:"Güneydoğu Anadolu", icon:"🍉", tags:["sur","karpuz","Dicle"], desc:"UNESCO Dünya Mirası bazalt sur duvarları ve dünyaca ünlü karpuzu ile antik şehir.", yemek:["Kaburga dolması","Çiğ köfte","Meftuné","Ciğer sarma"], gezilek:["Diyarbakır Surları","Hasanpaşa Hanı","Hevsel Bahçeleri","Ulu Cami"], ozellik:["UNESCO Diyarbakır Surları ve Hevsel Bahçeleri","Siyah bazalt surlar – dünyanın en uzunu","Dicle Nehri kıyısında"] },
  { name:"Düzce", region:"Batı Karadeniz", icon:"🏕️", tags:["fındık","rafting","orman"], desc:"Melen Çayı ve derin ormanlarıyla doğa sporlarının merkezi, fındık üretim başkenti.", yemek:["Fındık","Mısır ekmeği","Hamsi","Muhlama"], gezilek:["Melen Çayı","Akçakoca Sahili","Efteni Gölü"], ozellik:["Fındık üretim başkenti","Rafting ve kano sporları","Karadeniz kıyısına yakın"] },
  { name:"Edirne", region:"Marmara", icon:"🕌", tags:["Selimiye","güreş","köfte"], desc:"Osmanlı'nın ikinci başkenti; Selimiye Camii ve dünyanın en eski spor etkinliği Kırkpınar güreşiyle ünlü.", yemek:["Ciğer tava","Edirne köftesi","Badem ezmesi"], gezilek:["Selimiye Camii","Kırkpınar güreş alanı","Eski Cami","Meriç Nehri"], ozellik:["UNESCO Selimiye Camii","Kırkpınar – dünyanın en eski spor etkinliği","Osmanlı'nın 2. başkenti"] },
  { name:"Elazığ", region:"Doğu Anadolu", icon:"🍇", tags:["Keban","Harput","üzüm"], desc:"Keban Barajı ve Harput tarihi kalesinin gölgesinde, üzüm ve şarapıyla bilinen şehir.", yemek:["Harput köftesi","Firik çorbası","Tas kebabı"], gezilek:["Keban Barajı","Harput Kalesi","Buzluk Mağarası","Hazar Gölü"], ozellik:["Harput – Anadolu'nun önemli tarih merkezlerinden","Hazar Gölü doğal güzelliği","Keban Barajı gölet turizmi"] },
